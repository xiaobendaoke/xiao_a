{
  "$schema": "https://raw.githubusercontent.com/openclaw/openclaw/main/openclaw.schema.json",
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    },
    "auth": {
      "mode": "token"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "siliconflow/deepseek-ai/DeepSeek-V3.2"
      },
      "models": {
        "siliconflow/deepseek-ai/DeepSeek-V3.2": {
          "alias": "deepseek-chat"
        },
        "siliconflow/deepseek-ai/DeepSeek-R1": {
          "alias": "deepseek-reasoner"
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Agent",
        "model": "siliconflow/deepseek-ai/DeepSeek-V3.2"
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "siliconflow": {
        "baseUrl": "${SILICONFLOW_BASE_URL}",
        "apiKey": "${SILICONFLOW_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "deepseek-ai/DeepSeek-V3.2", "name": "DeepSeek-V3.2" },
          { "id": "deepseek-ai/DeepSeek-R1", "name": "DeepSeek-R1" }
        ]
      }
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000
      }
    }
  },
  "plugins": {
    "allow": [
      "xiao-services",
      "xiao-emotion",
      "xiao-core"
    ],
    "entries": {
      "xiao-services": {
        "enabled": true
      },
      "xiao-emotion": {
        "enabled": true
      },
      "xiao-core": {
        "enabled": true
      }
    }
  }
}
