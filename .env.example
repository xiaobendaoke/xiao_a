# ============================================================
# OpenClaw QQ channel runtime env template (OpenClaw-only)
# Target runtime: systemd --user + ~/.openclaw/.env
# ============================================================

# Gateway auth token
OPENCLAW_GATEWAY_TOKEN=change_me_openclaw_token

# Channel isolation (hard guard)
# Single value for strict isolation, e.g. qqbot OR feishu
XIAO_ALLOWED_CHANNELS=qqbot
# Default channel used by tools when caller does not pass a channel
XIAO_PRIMARY_CHANNEL=qqbot

# Model provider keys (choose one or more based on your openclaw.json)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=sk_placeholder

# QQ channel credentials (if your openclaw config reads env vars)
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=

# Feishu channel credentials (if your OpenClaw channel plugin reads env vars)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional: user-id bridge during migration
# Format: qqbot:<current_openid>=qqbot:<legacy_qq_id>[,qqbot:...=qqbot:...]
XIAO_USER_ALIAS_MAP=

# Optional: observability and media limits
XIAO_OBS_FILE=
XIAO_MEDIA_MAX_MB=20
XIAO_VISION_TIMEOUT_MS=35000
XIAO_ASR_TIMEOUT_MS=45000
XIAO_TTS_TIMEOUT_MS=45000
