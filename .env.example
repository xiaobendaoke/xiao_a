# SiliconFlow / DeepSeek / OpenAI（任选其一配置即可）
#
# 方案 A（推荐）：SiliconFlow 变量名
SILICONFLOW_API_KEY=your_token_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# Google Programmable Search（Custom Search JSON API，可选）
GOOGLE_CSE_API_KEY=your_google_api_key_here
GOOGLE_CSE_CX=your_search_engine_cx_here
GOOGLE_CSE_GL=cn
GOOGLE_CSE_HL=zh-CN
GOOGLE_CSE_PROXY=http://host.docker.internal:7890

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,napcat

# RSS（可选）：逗号/空格/换行分隔
RSS_FEEDS=

# xiao-emotion（可选）：账号映射与旧记忆库
# 示例：把当前 QQ OpenID 映射到旧账号，实现记忆连续
# XIAO_USER_ALIAS_MAP=qqbot:483A28BF8F1C0C061FED355643E43F76=qqbot:2107262208
# 旧记忆数据库路径（用于读取 user_profile/user_insights/chat_history）
# XIAO_LEGACY_DB_PATH=/root/xiao_a/data.db
#
# 方案 B：如果你已经在用 DEEPSEEK_* 变量名，也支持
# DEEPSEEK_API_KEY=your_token_here
# DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3
#
# 方案 C：OpenAI 官方/其他网关（只配 OPENAI_API_KEY）
# OPENAI_API_KEY=your_token_here

# =========================
# OpenClaw 侧车（方案A，可选）
# =========================
# 是否启用 OpenClaw 工具（默认关闭）
# OPENCLAW_TOOL_ENABLED=0
#
# 推荐：OpenAI兼容接口
# OPENCLAW_BASE_URL=http://openclaw:18789
# OPENCLAW_CHAT_PATH=/v1/chat/completions
# OPENCLAW_MODEL=openclaw
# OPENCLAW_AGENT_ID=main
#
# 鉴权：填 OpenClaw 网关 token（即 OPENCLAW_GATEWAY_TOKEN）
# OPENCLAW_API_KEY=change_me_openclaw_token
#
# 可选超时/参数
# OPENCLAW_TIMEOUT_MS=25000
# OPENCLAW_MAX_TOKENS=700

OPENCLAW_GATEWAY_TOKEN=change_me_openclaw_token
# OpenClaw 侧车默认走 DeepSeek 官方 API
OPENCLAW_DEEPSEEK_API_KEY=你的DeepSeekKey
# 可选：若你改成 OpenAI provider，再填这个
# OPENCLAW_OPENAI_API_KEY=你的OpenAIKey
